# ─── Backend ──────────────────────────────────────────────────────────────────
# Port the Go API listens on
SERVER_PORT=8080

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
DB_URL="postgres://postgres:password@localhost:5432/granth?sslmode=disable"

# Redis connection
REDIS_IP=localhost:6379
REDIS_PASSWORD=

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Port the Bun dev server listens on
FRONTEND_PORT=3000

# Base URL the browser uses to reach the API (must be localhost-accessible)
VITE_API_BASE_URL=http://localhost:8080/api
