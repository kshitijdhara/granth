{
	"name": "frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun run scripts/dev.ts",
		"build": "tsc --noEmit && bun run scripts/build.ts",
		"preview": "bun run scripts/preview.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint ./src",
		"format": "biome format ./src",
		"check": "biome check ./src",
		"check:write": "biome check --write ./src"
	},
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@types/react": "^19.2.5",
		"@types/react-dom": "^19.2.3",
		"bun-types": "latest",
		"sass": "^1.98.0",
		"typescript": "~5.9.3"
	}
}
